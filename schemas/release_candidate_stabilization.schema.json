{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.dev/schemas/release_candidate_stabilization.schema.json",
  "title": "Nornyx v0.9 Release-Candidate Stabilization Report",
  "type": "object",
  "required": ["schema", "target_version", "status", "summary", "checks", "required_validation", "safety"],
  "properties": {
    "schema": {
      "const": "nornyx.release_candidate_stabilization.v0.9"
    },
    "target_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["blocked", "release_candidate_stabilized_pending_approval", "release_candidate_stabilized_approved"]
    },
    "summary": {
      "type": "object",
      "required": ["passed", "warning", "blocked", "requires_human_approval"],
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "warning": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "requires_human_approval": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "message"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "warning", "blocked", "requires_human_approval"]},
          "message": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "required_validation": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "safety": {
      "type": "object",
      "required": [
        "published",
        "tag_created",
        "pushed_to_remote",
        "package_version_changed",
        "connectors_enabled",
        "network_used",
        "release_claim_made",
        "goal_042_completed_local",
        "goal_100_unlocked",
        "requires_human_release_approval"
      ],
      "properties": {
        "published": {"const": false},
        "tag_created": {"const": false},
        "pushed_to_remote": {"const": false},
        "package_version_changed": {"const": false},
        "connectors_enabled": {"const": false},
        "network_used": {"const": false},
        "release_claim_made": {"const": false},
        "goal_042_completed_local": {"type": "boolean"},
        "goal_100_unlocked": {"const": false},
        "requires_human_release_approval": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
