{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.dev/schemas/governance_evidence_v1.schema.json",
  "title": "Nornyx Governance Evidence Set v1",
  "description": "Normalized local evidence metadata. Hashes bind content; they do not prove truth.",
  "x-nornyx-governance-block": "governance_evidence",
  "type": "object",
  "required": ["schema", "subject_revision", "records"],
  "properties": {
    "schema": {"const": "nornyx.governance_evidence.v1"},
    "subject_revision": {"$ref": "#/$defs/revision"},
    "records": {
      "type": "array",
      "maxItems": 1000,
      "items": {"$ref": "#/$defs/evidenceRecord"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1, "maxLength": 256},
    "identity": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "revision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^\\S+$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifactPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "producer": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {"$ref": "#/$defs/identity"},
        "type": {"enum": ["human", "tool", "system", "external_service"]}
      },
      "additionalProperties": false
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"$ref": "#/$defs/identity"},
        "version": {"$ref": "#/$defs/nonEmpty"}
      },
      "additionalProperties": false
    },
    "evidenceRecord": {
      "type": "object",
      "required": [
        "id",
        "type",
        "schema_id",
        "producer",
        "artifact",
        "content_hash",
        "subject_revision",
        "tool",
        "generated_at",
        "expires_at",
        "status",
        "dependencies"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/identity"},
        "type": {"$ref": "#/$defs/identity"},
        "schema_id": {"$ref": "#/$defs/identity"},
        "producer": {"$ref": "#/$defs/producer"},
        "artifact": {"$ref": "#/$defs/artifactPath"},
        "content_hash": {"$ref": "#/$defs/sha256"},
        "subject_revision": {"$ref": "#/$defs/revision"},
        "tool": {"$ref": "#/$defs/tool"},
        "generated_at": {"$ref": "#/$defs/timestamp"},
        "expires_at": {
          "oneOf": [
            {"$ref": "#/$defs/timestamp"},
            {"type": "null"}
          ]
        },
        "status": {"enum": ["pass", "fail", "inconclusive", "observed"]},
        "dependencies": {
          "type": "array",
          "maxItems": 100,
          "items": {"$ref": "#/$defs/identity"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
