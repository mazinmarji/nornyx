{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.local/schemas/pattern_lifecycle.schema.json",
  "title": "Nornyx AI Pattern Lifecycle",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "status",
    "problem",
    "solution",
    "applicability",
    "validation",
    "evidence",
    "risks",
    "failure_modes",
    "promotion_criteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "prompt",
        "context",
        "agent_workflow",
        "harness",
        "eval",
        "evidence",
        "tool_integration",
        "portal_renderer",
        "security_guardrail"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "experimental",
        "evaluated",
        "candidate",
        "stable",
        "deprecated"
      ]
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "solution": {
      "type": "string",
      "minLength": 1
    },
    "applicability": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "promotion_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deprecation_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
