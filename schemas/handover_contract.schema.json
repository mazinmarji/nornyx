{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.local/schemas/handover_contract.schema.json",
  "title": "Nornyx Handover Contract",
  "type": "object",
  "required": [
    "name",
    "from_state",
    "to_state",
    "required",
    "approval",
    "evidence"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "from_state": {
      "type": "string",
      "minLength": 1
    },
    "to_state": {
      "type": "string",
      "minLength": 1
    },
    "required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approval": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "blocking_open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
