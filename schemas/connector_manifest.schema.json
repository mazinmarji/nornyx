{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.dev/schemas/connector_manifest.schema.json",
  "title": "Nornyx Connector Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "protocol", "capabilities"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "protocol": {
      "type": "string",
      "enum": ["MCP", "mcp", "A2A", "a2a"]
    },
    "version": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deny": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "share": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "never_share": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requires_approval": {
          "type": "boolean",
          "default": true
        },
        "default_mode": {
          "type": "string",
          "enum": ["disabled", "read_only", "read-only", "metadata_only", "manifest_only", "contract_only"]
        }
      }
    }
  }
}
