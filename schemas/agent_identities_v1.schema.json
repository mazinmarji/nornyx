{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.dev/schemas/agent_identities_v1.schema.json",
  "title": "Nornyx Agent Identities v1",
  "description": "Bounded non-human identity declarations linked to existing role-oriented agents.",
  "x-nornyx-governance-block": "agent_identities",
  "type": "array",
  "maxItems": 1024,
  "items": {"$ref": "#/$defs/identity"},
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "ids": {
      "type": "array",
      "maxItems": 256,
      "items": {"$ref": "#/$defs/id"},
      "uniqueItems": true
    },
    "timestamp": {
      "type": "string",
      "minLength": 20,
      "maxLength": 40,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "frameworkBinding": {
      "type": "object",
      "required": ["framework", "agent_key"],
      "properties": {
        "framework": {"$ref": "#/$defs/id"},
        "agent_key": {"$ref": "#/$defs/id"}
      },
      "additionalProperties": false
    },
    "identity": {
      "type": "object",
      "required": [
        "id",
        "role_ref",
        "identity_class",
        "namespace",
        "subject",
        "framework_bindings",
        "capability_refs",
        "status",
        "valid_from",
        "expires_at",
        "revocation_refs",
        "authority",
        "can_approve"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "role_ref": {"$ref": "#/$defs/id"},
        "identity_class": {
          "enum": ["local_agent", "external_agent", "service_agent", "test_agent"]
        },
        "namespace": {"$ref": "#/$defs/id"},
        "subject": {"$ref": "#/$defs/id"},
        "framework_bindings": {
          "type": "array",
          "maxItems": 32,
          "items": {"$ref": "#/$defs/frameworkBinding"},
          "uniqueItems": true
        },
        "capability_refs": {"$ref": "#/$defs/ids"},
        "status": {"enum": ["active", "suspended", "revoked", "expired"]},
        "valid_from": {"$ref": "#/$defs/timestamp"},
        "expires_at": {"$ref": "#/$defs/timestamp"},
        "revocation_refs": {"$ref": "#/$defs/ids"},
        "authority": {"const": "non_human"},
        "can_approve": {"const": false}
      },
      "additionalProperties": false
    }
  }
}
