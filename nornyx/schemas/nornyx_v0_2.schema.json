{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.local/schemas/nornyx_v0_2.schema.json",
  "title": "Nornyx v0.2 Static Graph and Contract Schema",
  "x-nornyx-schema-role": "versioned_schema",
  "x-nornyx-supported-versions": ["0.2"],
  "x-nornyx-version-note": "Explicit v0.2 schema target for the static graph and generic contract surface. This schema is validation-only and does not enable graph runtime execution.",
  "type": "object",
  "required": ["nornyx", "project"],
  "additionalProperties": false,
  "properties": {
    "nornyx": {
      "oneOf": [
        {"const": "0.2"},
        {"const": 0.2}
      ]
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "constitution": {
      "type": "object",
      "additionalProperties": true
    },
    "intents": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "contexts": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "skills": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "policies": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "agents": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "harnesses": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "traces": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "evals": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "evidence": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": true
    },
    "approvals": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "budgets": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "goals": {
      "type": "array",
      "items": {"$ref": "#/$defs/goal"}
    },
    "experimental": {
      "type": "object",
      "additionalProperties": true
    },
    "graph": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {"$ref": "#/$defs/graphNode"}
        },
        "edges": {
          "type": "array",
          "items": {"$ref": "#/$defs/graphEdge"}
        }
      },
      "additionalProperties": true
    },
    "contracts": {
      "type": "array",
      "items": {"$ref": "#/$defs/contract"}
    },
    "governed_package": {
      "type": "object",
      "additionalProperties": true
    },
    "adapters": {
      "type": "array",
      "items": {"$ref": "#/$defs/adapter"}
    },
    "connectors": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "guardrails": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "capabilities": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "incidents": {
      "type": "array",
      "items": {"$ref": "#/$defs/namedMapping"}
    },
    "containment": {
      "type": "object",
      "additionalProperties": true
    },
    "supply_chain": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "namedMapping": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "graphNode": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "graphEdge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {"type": "string", "minLength": 1},
        "to": {"type": "string", "minLength": 1},
        "relation": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "contract": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "nodes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "edges": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "approval": {"type": "string", "minLength": 1},
        "budget": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "adapter": {
      "type": "object",
      "required": ["name", "kind", "execution_mode", "live_connector_execution"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "target_profile": {"type": "string", "minLength": 1},
        "execution_mode": {"const": "contract_only"},
        "live_connector_execution": {"const": false},
        "connector_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "policy_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "eval_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": true
    },
    "goal": {
      "type": "object",
      "required": [
        "id",
        "phase",
        "goal",
        "scope",
        "non_goals",
        "validation",
        "evidence",
        "approval",
        "stop_rules"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string"},
        "phase": {"type": "string", "minLength": 1},
        "goal": {"type": "string", "minLength": 1},
        "scope": {"$ref": "#/$defs/stringList"},
        "non_goals": {"$ref": "#/$defs/stringList"},
        "validation": {"$ref": "#/$defs/stringList"},
        "evidence": {"type": "string", "minLength": 1},
        "approval": {"type": "string", "minLength": 1},
        "stop_rules": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": true
    }
  }
}
