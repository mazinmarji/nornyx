{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.dev/schemas/governed_package.schema.json",
  "title": "Nornyx Governed Package Profile",
  "type": "object",
  "required": [
    "profile",
    "schema_version",
    "package_id",
    "name",
    "mission",
    "tasks",
    "changes",
    "evidence",
    "approval_gates",
    "risk_tier",
    "artifacts",
    "installation_policy",
    "safety_boundary",
    "provenance"
  ],
  "properties": {
    "profile": {
      "const": "governed_package"
    },
    "schema_version": {
      "type": "string"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "registration_mode": {
      "enum": ["generated", "existing"]
    },
    "mission": {
      "type": "object",
      "required": ["id", "objective"],
      "properties": {
        "id": {"type": "string"},
        "objective": {"type": "string"},
        "scope": {"type": "object"}
      },
      "additionalProperties": true
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "assigned_to": {"type": "string"},
          "required_evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "expected_artifacts": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "object",
      "required": ["requirements"],
      "properties": {
        "requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "required"],
            "properties": {
              "id": {"type": "string"},
              "type": {"type": "string"},
              "required": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "approval_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "required_evidence", "eligible_approver_roles"],
        "properties": {
          "id": {"type": "string"},
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "eligible_approver_roles": {"type": "array", "items": {"type": "string"}},
          "denied_approver_types": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "risk_tier": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "agent_assignments": {
      "type": "array",
      "items": {"type": "object"}
    },
    "execution_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "can_approve"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "can_approve": {"const": false},
          "produces_evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "type"],
        "properties": {
          "id": {"type": "string"},
          "path": {"type": "string"},
          "type": {"type": "string"},
          "sha256": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "installation_policy": {
      "type": "object",
      "required": ["installed", "executable_by_default", "requires_explicit_install"],
      "properties": {
        "installed": {"const": false},
        "executable_by_default": {"const": false},
        "requires_explicit_install": {"const": true}
      },
      "additionalProperties": false
    },
    "safety_boundary": {
      "type": "object",
      "required": [
        "secrets_allowed",
        "production_data_allowed",
        "autonomous_execution_allowed",
        "external_writes_allowed",
        "deployment_allowed",
        "approval_required"
      ],
      "properties": {
        "secrets_allowed": {"const": false},
        "production_data_allowed": {"const": false},
        "autonomous_execution_allowed": {"const": false},
        "external_writes_allowed": {"const": false},
        "deployment_allowed": {"const": false},
        "approval_required": {"const": true}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["source_sha256", "generator_version", "profile_version"],
      "properties": {
        "source_contract": {"type": "string"},
        "source_sha256": {"type": "string"},
        "generator_name": {"type": "string"},
        "generator_version": {"type": "string"},
        "profile_version": {"type": "string"},
        "generated_at": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
