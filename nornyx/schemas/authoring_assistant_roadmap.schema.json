{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.local/schemas/authoring_assistant_roadmap.schema.json",
  "title": "Nornyx Authoring Assistant Roadmap",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "name",
    "purpose",
    "capabilities",
    "authority_rules",
    "promotion_gates",
    "blocked_actions",
    "non_goals",
    "next_focus"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "roadmap",
        "experimental",
        "candidate",
        "stable"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "description",
          "priority",
          "safe_now"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "roadmap",
              "research",
              "experimental",
              "candidate",
              "stable"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "safe_now": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "authority_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "promotion_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_\\-]+$"
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_focus": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
