{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.dev/schemas/agentic_runtime_events_v1.schema.json",
  "title": "Nornyx Agentic Runtime Events v1",
  "description": "Closed envelope for supplied local runtime-event evidence. Events are records offered for validation against an exact contract, lock, and revision. Accepting an event proves conformance of the supplied record only; hash validity proves content binding, not event truth. This schema defines no transport, endpoint, credential, or execution behavior.",
  "type": "object",
  "required": ["schema", "schema_version", "network_id", "producer", "events"],
  "properties": {
    "schema": {"const": "nornyx.agentic_runtime_events.v1"},
    "schema_version": {"const": "1.0"},
    "network_id": {"$ref": "#/$defs/id"},
    "producer": {"$ref": "#/$defs/producer"},
    "events": {
      "type": "array",
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/event"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "sha256Digest": {
      "type": "string",
      "minLength": 71,
      "maxLength": 71,
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "subjectRevision": {
      "type": "string",
      "minLength": 44,
      "maxLength": 71,
      "pattern": "^(?:git:(?:[0-9a-f]{40}|[0-9a-f]{64})|sha256:[0-9a-f]{64})$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 20,
      "maxLength": 40,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "producer": {
      "type": "object",
      "required": ["type", "id", "version"],
      "properties": {
        "type": {
          "enum": [
            "framework_adapter",
            "synthetic_harness",
            "external_runtime"
          ]
        },
        "id": {"$ref": "#/$defs/id"},
        "version": {"$ref": "#/$defs/id"}
      },
      "additionalProperties": false
    },
    "approver": {
      "type": "object",
      "required": ["role", "actor_type"],
      "properties": {
        "role": {"$ref": "#/$defs/id"},
        "actor_type": {
          "enum": [
            "human",
            "ai_tool",
            "execution_surface",
            "autonomous_agent",
            "model",
            "connector",
            "generated_output"
          ]
        }
      },
      "additionalProperties": false
    },
    "evidenceArtifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64,
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": [
        "event_id",
        "event_type",
        "mission_id",
        "sequence",
        "actor_ref",
        "timestamp",
        "network_id",
        "contract_digest",
        "network_lock_digest",
        "subject_revision",
        "producer"
      ],
      "properties": {
        "event_id": {"$ref": "#/$defs/id"},
        "event_type": {
          "enum": [
            "agent_invoked",
            "capability_requested",
            "capability_allowed",
            "capability_denied",
            "delegation_requested",
            "delegation_accepted",
            "delegation_rejected",
            "handoff_initiated",
            "handoff_completed",
            "trust_zone_crossed",
            "data_shared",
            "approval_requested",
            "approval_granted",
            "approval_rejected",
            "tool_invoked",
            "policy_violation",
            "identity_revoked",
            "runtime_failed"
          ]
        },
        "mission_id": {"$ref": "#/$defs/id"},
        "sequence": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "actor_ref": {"$ref": "#/$defs/id"},
        "target_ref": {"$ref": "#/$defs/id"},
        "capability_ref": {"$ref": "#/$defs/id"},
        "delegation_ref": {"$ref": "#/$defs/id"},
        "handoff_ref": {"$ref": "#/$defs/id"},
        "source_zone_ref": {"$ref": "#/$defs/id"},
        "target_zone_ref": {"$ref": "#/$defs/id"},
        "policy_decision": {"enum": ["allow", "deny"]},
        "approval_ref": {"$ref": "#/$defs/id"},
        "approver": {"$ref": "#/$defs/approver"},
        "share_categories": {
          "type": "array",
          "maxItems": 64,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "timestamp": {"$ref": "#/$defs/timestamp"},
        "network_id": {"$ref": "#/$defs/id"},
        "contract_digest": {"$ref": "#/$defs/sha256Digest"},
        "network_lock_digest": {"$ref": "#/$defs/sha256Digest"},
        "subject_revision": {"$ref": "#/$defs/subjectRevision"},
        "input_digest": {"$ref": "#/$defs/sha256Digest"},
        "output_digest": {"$ref": "#/$defs/sha256Digest"},
        "producer": {"$ref": "#/$defs/producer"},
        "evidence_artifact": {"$ref": "#/$defs/evidenceArtifact"},
        "signature_ref": {"$ref": "#/$defs/id"},
        "depends_on": {
          "type": "array",
          "maxItems": 64,
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
