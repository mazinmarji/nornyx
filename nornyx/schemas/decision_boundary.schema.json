{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nornyx.local/schemas/decision_boundary.schema.json",
  "title": "Nornyx Decision Boundary",
  "type": "object",
  "required": [
    "name",
    "ai_allowed",
    "ai_denied",
    "human_owner",
    "approval_required",
    "evidence_required"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "ai_allowed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ai_denied": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "human_owner": {
      "type": "string",
      "minLength": 1
    },
    "approval_required": {
      "type": "boolean"
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_until": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
